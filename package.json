{
  "name": "gust",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "format": "oxfmt --ignore-path=.oxfmtignore --write .",
    "format:check": "oxfmt --ignore-path=.oxfmtignore --check .",
    "lint": "turbo run lint",
    "registry:build": "bun run --cwd packages/registry build",
    "registry:check": "bun run --cwd packages/registry check",
    "test": "turbo run test",
    "test:browser": "playwright test",
    "typecheck": "tsc --noEmit -p tsconfig.json && turbo run typecheck",
    "verify": "bun run format:check && bun run lint && bun run typecheck && bun run test && bun run registry:check && bun run test:browser && bun run build"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.9.2",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "postcss": "^8.5.6",
    "shadcn": "^4.12.0",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.3.11"
}
