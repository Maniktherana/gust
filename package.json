{
	"name": "gust",
	"version": "0.1.0",
	"private": true,
	"description": "Animated text transitions for React, available through npm or shadcn.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Maniktherana/gust.git"
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "turbo run lint",
		"format": "turbo run format",
		"format:check": "turbo run format:check",
		"typecheck": "turbo run typecheck",
		"test": "turbo run test",
		"test:browser": "playwright test",
		"release:major": "bash scripts/release.sh major",
		"release:minor": "bash scripts/release.sh minor",
		"release:patch": "bash scripts/release.sh patch",
		"registry:build": "bun run --cwd apps/site registry:build",
		"registry:check": "bun run --cwd apps/site registry:check"
	},
	"devDependencies": {
		"@playwright/test": "^1.58.2",
		"@types/bun": "^1.3.11",
		"@types/node": "^25.9.2",
		"oxfmt": "^0.54.0",
		"oxlint": "^1.69.0",
		"turbo": "^2.9.16",
		"typescript": "^6.0.3"
	},
	"packageManager": "bun@1.3.11",
	"patchedDependencies": {
		"liveline@0.0.7": "patches/liveline@0.0.7.patch"
	}
}
