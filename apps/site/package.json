{
  "name": "@gust/site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3002",
    "prebuild": "bun registry/build-static.ts",
    "build": "vite build",
    "preview": "vite preview",
    "registry:build": "bun registry/build-registry.ts && bun registry/build-static.ts",
    "registry:check": "bun registry/build-registry.ts --check && bun registry/build-static.ts",
    "start": "bun .output/server/index.mjs",
    "test": "bun test registry",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --ignore-path=.oxfmtignore --write .",
    "format:check": "oxfmt --ignore-path=.oxfmtignore --check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/geist-mono": "5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@maniktherana/gust": "workspace:*",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-start": "^1.168.25",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "liveline": "^0.0.7",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "react": "19",
    "react-dom": "19",
    "shiki": "^4.3.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "nitro": "^3.0.260603-beta",
    "postcss": "^8.5.6",
    "shadcn": "^4.12.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8"
  }
}
