{
  "name": "@maniktherana/gust",
  "version": "0.1.0",
  "description": "Animated text transitions for React.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Maniktherana/gust.git",
    "directory": "packages/gust"
  },
  "files": [
    "dist",
    "src/gust.css"
  ],
  "type": "module",
  "sideEffects": [
    "./src/gust.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./src/gust.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "lint": "oxlint src tests",
    "prepublishOnly": "bun run build && bun run test",
    "test": "bun test tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/react": "^19.2.17",
    "react": "19",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
